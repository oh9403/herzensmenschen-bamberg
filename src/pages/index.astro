---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Vision from '../components/Vision.astro';
import Values from '../components/Values.astro';
import SuspendedCoffee from '../components/SuspendedCoffee.astro';
import Offerings from '../components/Offerings.astro';
import Founder from '../components/Founder.astro';
import CTA from '../components/CTA.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main id="main-content">
    <Hero />
    <Vision />
    <Values />
    <SuspendedCoffee />
    <Offerings />
    <Founder />
    <CTA />
    <Newsletter />
  </main>
  <Footer />
</Layout>
