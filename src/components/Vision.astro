---
---

<section
  id="vision"
  class="relative py-24 lg:py-32 overflow-hidden"
  style="background: linear-gradient(160deg, var(--cream) 0%, var(--cream-deep) 100%);"
  aria-labelledby="vision-heading"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Left: Illustration + Quote -->
      <div id="vision-left" class="flex flex-col items-center lg:items-start gap-10">

        <!-- Hands SVG Illustration -->
        <div class="relative">
          <svg
            viewBox="0 0 320 280"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full max-w-sm mx-auto"
            aria-hidden="true"
          >
            <!-- Left hand -->
            <path
              d="M 60,220 Q 55,180 65,150 Q 72,130 80,120 Q 90,108 95,125 Q 98,118 105,115 Q 114,112 116,128 Q 120,120 128,118 Q 138,116 138,134 L 138,155 Q 148,148 158,150 Q 168,153 166,168 L 162,200 Q 158,220 148,232 Q 132,245 110,248 Q 88,250 72,238 Z"
              stroke="var(--soft-brown)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="var(--cream-dark)"
              fill-opacity="0.6"
            />
            <!-- Left hand fingers detail -->
            <path d="M 80,120 L 78,100 Q 78,90 86,90 Q 94,90 95,100 L 95,125" stroke="var(--soft-brown)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <path d="M 105,115 L 104,92 Q 104,82 112,82 Q 120,82 120,92 L 116,128" stroke="var(--soft-brown)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <path d="M 128,118 L 128,98 Q 128,88 136,88 Q 144,88 144,98 L 138,134" stroke="var(--soft-brown)" stroke-width="1.8" stroke-linecap="round" fill="none"/>

            <!-- Right hand (mirrored, offset) -->
            <path
              d="M 260,220 Q 265,180 255,150 Q 248,130 240,120 Q 230,108 225,125 Q 222,118 215,115 Q 206,112 204,128 Q 200,120 192,118 Q 182,116 182,134 L 182,155 Q 172,148 162,150 Q 152,153 154,168 L 158,200 Q 162,220 172,232 Q 188,245 210,248 Q 232,250 248,238 Z"
              stroke="var(--soft-brown)"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="var(--cream-dark)"
              fill-opacity="0.6"
            />
            <!-- Right hand fingers detail -->
            <path d="M 240,120 L 242,100 Q 242,90 234,90 Q 226,90 225,100 L 225,125" stroke="var(--soft-brown)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <path d="M 215,115 L 216,92 Q 216,82 208,82 Q 200,82 200,92 L 204,128" stroke="var(--soft-brown)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
            <path d="M 192,118 L 192,98 Q 192,88 184,88 Q 176,88 176,98 L 182,134" stroke="var(--soft-brown)" stroke-width="1.8" stroke-linecap="round" fill="none"/>

            <!-- Heart in the center, held between hands -->
            <path
              d="M 160,170 C 160,158 144,152 144,166 C 144,175 160,188 160,188 C 160,188 176,175 176,166 C 176,152 160,158 160,170 Z"
              stroke="var(--warm-gold)"
              stroke-width="2"
              fill="var(--warm-gold)"
              fill-opacity="0.2"
            />

            <!-- Decorative dots -->
            <circle cx="50" cy="80" r="5" fill="var(--sage)" opacity="0.35"/>
            <circle cx="270" cy="75" r="4" fill="var(--terracotta-light)" opacity="0.3"/>
            <circle cx="160" cy="40" r="6" fill="var(--warm-gold)" opacity="0.25"/>
            <circle cx="40" cy="240" r="3" fill="var(--warm-gold)" opacity="0.2"/>
          </svg>
        </div>

        <!-- Quote block -->
        <blockquote
          class="relative p-6 rounded-[var(--radius-md)] border-l-4 max-w-sm"
          style="background: var(--cream); border-left-color: var(--warm-gold); box-shadow: var(--shadow-sm);"
        >
          <p
            class="font-serif text-xl leading-snug italic"
            style="color: var(--text-primary);"
          >
            »Sorgen sind hier genauso willkommen wie gute Laune.«
          </p>
          <div
            class="absolute -top-3 -left-1 text-4xl leading-none"
            style="color: var(--warm-gold); opacity: 0.4;"
            aria-hidden="true"
          >
            ♡
          </div>
        </blockquote>
      </div>

      <!-- Right: Text Content -->
      <div id="vision-right">
        <!-- Label -->
        <span class="section-label mb-4 block">Unsere Vision</span>

        <!-- H2 -->
        <h2
          id="vision-heading"
          class="font-serif text-4xl lg:text-5xl leading-tight mb-4"
          style="color: var(--text-primary); letter-spacing: -0.01em;"
        >
          Ein Bindeglied, das Bamberg bisher fehlt
        </h2>

        <!-- Gold divider -->
        <hr id="vision-divider" class="gold-divider mb-8" />

        <!-- Paragraphs -->
        <p
          class="font-sans text-base lg:text-lg leading-relaxed mb-6"
          style="color: var(--text-secondary);"
        >
          Was in Bamberg fehlt, ist ein Ort zwischen den Beratungsstellen – ein warmer Raum,
          in dem Menschen in herausfordernden Situationen Kraft schöpfen und Rückhalt finden
          können. Bevor sie bereit sind, einen Beratungstermin bei der Caritas, Diakonie,
          dem Frauenhaus oder dem Weißen Ring zu vereinbaren. Oder um sich auf einen solchen
          Termin vorzubereiten.
        </p>

        <p
          class="font-sans text-base lg:text-lg leading-relaxed"
          style="color: var(--text-secondary);"
        >
          Unser Café soll dieser Ort sein: ein zwangloser Treffpunkt, der Menschen aller
          Altersklassen aus der Einsamkeit lockt, ihnen den Rücken stärkt und sie miteinander
          verbindet – ganz ohne Verpflichtungen.
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // Illustration slides in from left
    gsap.fromTo(
      '#vision-left',
      { x: -40, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#vision',
          start: 'top 75%',
          once: true,
        },
      }
    );

    // Text slides in from right
    gsap.fromTo(
      '#vision-right',
      { x: 40, opacity: 0 },
      {
        x: 0,
        opacity: 1,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '#vision',
          start: 'top 75%',
          once: true,
        },
      }
    );

    // Gold line scaleX 0 → 1
    gsap.fromTo(
      '#vision-divider',
      { scaleX: 0, opacity: 0 },
      {
        scaleX: 1,
        opacity: 1,
        duration: 0.9,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: '#vision-divider',
          start: 'top 85%',
          once: true,
        },
      }
    );
  }
</script>
