---
const offerings = [
  {
    title: 'Kaffeeklatsch zum offenen Ohr',
    description:
      'Unser monatliches Herzformat – seit drei Jahren ein fester Treffpunkt für Gespräche, die gut tun.',
    icon: 'coffee',
  },
  {
    title: 'Selbstliebe to go',
    description:
      'Bewährtes Kursformat zur Stärkung des Selbstwertgefühls und der inneren Kraft.',
    icon: 'heart',
  },
  {
    title: 'Kreativ- & Wohlfühlangebote',
    description:
      'Yoga, Malen, Stricken und mehr – Menschen geben weiter, was sie gut können.',
    icon: 'brush',
  },
  {
    title: 'Beratung vor der Beratung',
    description:
      'Orientierung zu Anlaufstellen wie Caritas, Diakonie, Frauenhaus oder Weißer Ring.',
    icon: 'compass',
  },
  {
    title: 'Wiedereingliederung & Inklusion',
    description:
      'Unterstützung z. B. nach dem Aufenthalt im Frauenhaus, inklusive Inklusionsangebote.',
    icon: 'inclusion',
  },
  {
    title: 'Vernetzung & Gemeinschaft',
    description:
      'Austausch über Social Media, Begleitung zu Terminen, schnelle Hilfe auf kurzen Wegen.',
    icon: 'network',
  },
];
---

<section
  id="angebote"
  class="relative py-24 lg:py-32 overflow-hidden"
  style="background: var(--deep-brown);"
  aria-labelledby="offerings-heading"
>
  <!-- Terracotta blob decoration -->
  <div
    class="blob blob-terracotta absolute top-0 right-0"
    style="width: 400px; height: 400px; opacity: 0.08; border-radius: 50% 20% 60% 30% / 40% 60% 30% 50%;"
    aria-hidden="true"
  ></div>
  <!-- Sage blob bottom left -->
  <div
    class="absolute bottom-0 left-0 pointer-events-none"
    style="width: 300px; height: 300px; background: var(--sage); opacity: 0.04; border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span
        class="section-label mb-4 block"
        style="color: var(--warm-gold);"
      >
        Unsere Angebote
      </span>
      <h2
        id="offerings-heading"
        class="font-serif text-4xl lg:text-5xl leading-tight mb-4"
        style="color: var(--cream); letter-spacing: -0.01em;"
      >
        Mehr als nur Kaffee
      </h2>
      <p
        class="font-sans text-base lg:text-lg leading-relaxed"
        style="color: var(--cream-dark);"
      >
        Das Café als Herz, mit vielfältigen Zusatzangeboten – getragen von Ehrenamtlichen
        und der Gemeinschaft.
      </p>
    </div>

    <!-- Offerings Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6" id="offerings-grid">

      {offerings.map((offering) => (
        <div
          class="offering-item p-7 rounded-[var(--radius-md)] relative overflow-hidden group"
          style="border: 1px solid rgba(212, 160, 86, 0.2); transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;"
        >
          <!-- Glow effect on hover -->
          <div
            class="offering-glow absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300"
            style="background: radial-gradient(ellipse at 50% 50%, rgba(212,160,86,0.08), transparent 70%);"
            aria-hidden="true"
          ></div>

          <!-- Icon -->
          <div class="mb-5 relative z-10" aria-hidden="true">
            {offering.icon === 'coffee' && (
              <svg viewBox="0 0 48 48" fill="none" class="w-11 h-11" aria-hidden="true">
                <path d="M10 20 Q9 30 12 36 Q18 42 24 42 Q30 42 36 36 Q39 30 38 20 Z" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 20 Q24 16 40 20" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M38 26 Q46 24 45 32 Q44 40 37 38" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <path d="M17 14 Q15 10 18 7 Q21 4 19 1" stroke="var(--warm-gold-light)" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.7"/>
                <path d="M25 13 Q23 8 26 5 Q29 2 27 -1" stroke="var(--warm-gold-light)" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.7"/>
              </svg>
            )}
            {offering.icon === 'heart' && (
              <svg viewBox="0 0 48 48" fill="none" class="w-11 h-11" aria-hidden="true">
                <path d="M24 40 C24 40 8 28 8 18 C8 12 12.5 8 18 8 C21 8 24 10 24 10 C24 10 27 8 30 8 C35.5 8 40 12 40 18 C40 28 24 40 24 40 Z" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M18 20 Q24 16 30 20" stroke="var(--warm-gold-light)" stroke-width="2" stroke-linecap="round" opacity="0.6"/>
              </svg>
            )}
            {offering.icon === 'brush' && (
              <svg viewBox="0 0 48 48" fill="none" class="w-11 h-11" aria-hidden="true">
                <!-- Paintbrush -->
                <path d="M10 38 Q14 42 18 40 Q22 38 20 34 Q16 30 12 32 Q8 34 10 38 Z" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M18 36 L36 12 Q38 8 35 7 Q32 6 30 10 Z" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Knitting needles -->
                <line x1="28" y1="36" x2="44" y2="8" stroke="var(--sage-light)" stroke-width="2.5" stroke-linecap="round" opacity="0.8"/>
                <line x1="34" y1="40" x2="46" y2="16" stroke="var(--sage-light)" stroke-width="2.5" stroke-linecap="round" opacity="0.8"/>
              </svg>
            )}
            {offering.icon === 'compass' && (
              <svg viewBox="0 0 48 48" fill="none" class="w-11 h-11" aria-hidden="true">
                <circle cx="24" cy="24" r="18" stroke="var(--warm-gold)" stroke-width="2.5"/>
                <circle cx="24" cy="24" r="3" fill="var(--warm-gold)" fill-opacity="0.5" stroke="var(--warm-gold)" stroke-width="2"/>
                <!-- Compass needle -->
                <path d="M24 24 L18 12 L24 16 Z" stroke="var(--warm-gold)" stroke-width="1.5" fill="var(--warm-gold)" fill-opacity="0.7" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M24 24 L30 36 L24 32 Z" stroke="var(--cream-dark)" stroke-width="1.5" fill="var(--cream-dark)" fill-opacity="0.5" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Cardinal points -->
                <text x="24" y="10" text-anchor="middle" font-size="5" fill="var(--warm-gold-light)" font-family="Outfit" opacity="0.8">N</text>
                <text x="24" y="43" text-anchor="middle" font-size="5" fill="var(--warm-gold-light)" font-family="Outfit" opacity="0.8">S</text>
              </svg>
            )}
            {offering.icon === 'inclusion' && (
              <svg viewBox="0 0 48 48" fill="none" class="w-11 h-11" aria-hidden="true">
                <circle cx="16" cy="12" r="4" stroke="var(--warm-gold)" stroke-width="2.5"/>
                <circle cx="32" cy="12" r="4" stroke="var(--warm-gold)" stroke-width="2.5"/>
                <path d="M8 32 C8 25 11 22 16 22 C21 22 24 25 24 32" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M24 32 C24 25 27 22 32 22 C37 22 40 25 40 32" stroke="var(--warm-gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <!-- Arrow -->
                <path d="M20 40 L28 40 M25 37 L28 40 L25 43" stroke="var(--warm-gold-light)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
              </svg>
            )}
            {offering.icon === 'network' && (
              <svg viewBox="0 0 48 48" fill="none" class="w-11 h-11" aria-hidden="true">
                <circle cx="24" cy="24" r="4" fill="var(--warm-gold)" fill-opacity="0.5" stroke="var(--warm-gold)" stroke-width="2"/>
                <circle cx="8" cy="12" r="3" stroke="var(--warm-gold)" stroke-width="2"/>
                <circle cx="40" cy="12" r="3" stroke="var(--warm-gold)" stroke-width="2"/>
                <circle cx="8" cy="36" r="3" stroke="var(--warm-gold)" stroke-width="2"/>
                <circle cx="40" cy="36" r="3" stroke="var(--warm-gold)" stroke-width="2"/>
                <line x1="11" y1="14" x2="21" y2="22" stroke="var(--warm-gold-light)" stroke-width="1.5" opacity="0.6"/>
                <line x1="37" y1="14" x2="27" y2="22" stroke="var(--warm-gold-light)" stroke-width="1.5" opacity="0.6"/>
                <line x1="11" y1="34" x2="21" y2="26" stroke="var(--warm-gold-light)" stroke-width="1.5" opacity="0.6"/>
                <line x1="37" y1="34" x2="27" y2="26" stroke="var(--warm-gold-light)" stroke-width="1.5" opacity="0.6"/>
                <line x1="8" y1="15" x2="8" y2="33" stroke="var(--warm-gold-light)" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
                <line x1="40" y1="15" x2="40" y2="33" stroke="var(--warm-gold-light)" stroke-width="1" stroke-dasharray="3 3" opacity="0.4"/>
              </svg>
            )}
          </div>

          <!-- Title -->
          <h3
            class="font-serif text-xl mb-3 relative z-10"
            style="color: var(--cream);"
          >
            {offering.title}
          </h3>

          <!-- Description -->
          <p
            class="font-sans text-sm leading-relaxed relative z-10"
            style="color: var(--cream-dark);"
          >
            {offering.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .offering-item:hover {
    border-color: rgba(212, 160, 86, 0.5) !important;
    box-shadow: 0 0 32px rgba(212, 160, 86, 0.12);
    background: rgba(255, 255, 255, 0.03);
  }

  .offering-item:hover .offering-glow {
    opacity: 1;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    gsap.fromTo(
      '.offering-item',
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.65,
        ease: 'power3.out',
        stagger: 0.12,
        scrollTrigger: {
          trigger: '#offerings-grid',
          start: 'top 80%',
          once: true,
        },
      }
    );
  }
</script>
