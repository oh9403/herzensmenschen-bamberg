---
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  style="background: radial-gradient(ellipse at 30% 50%, var(--cream-deep) 0%, var(--cream) 60%);"
  aria-label="Hero-Bereich"
>
  <!-- Dots background pattern -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(var(--soft-brown) 1px, transparent 1px); background-size: 32px 32px; opacity: 0.04;"
    aria-hidden="true"
  ></div>

  <!-- Blob decorations -->
  <div
    id="hero-blob-1"
    class="blob blob-terracotta"
    style="width: 520px; height: 480px; top: -100px; right: -120px; opacity: 0;"
    aria-hidden="true"
  ></div>
  <div
    id="hero-blob-2"
    class="blob blob-sage"
    style="width: 380px; height: 420px; bottom: -80px; left: -100px; border-radius: 45% 55% 40% 60% / 55% 45% 60% 40%; opacity: 0;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full pt-28 pb-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text Content -->
      <div class="text-left lg:text-left">
        <!-- Badge -->
        <div
          id="hero-badge"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full border mb-8 opacity-0"
          style="background: var(--cream); border-color: var(--terracotta); border-width: 1.5px;"
        >
          <span style="color: var(--warm-gold);">♡</span>
          <span class="font-serif text-sm" style="color: var(--terracotta);">
            Verein Herzensmenschen Bamberg
          </span>
        </div>

        <!-- Headline -->
        <h1
          class="font-serif mb-6 leading-[1.1]"
          style="font-size: clamp(3rem, 7vw, 5rem); letter-spacing: -0.02em; color: var(--text-primary);"
        >
          <span id="hero-word-1" class="block opacity-0">Kaffeeklatsch zum</span>
          <span id="hero-word-2" class="block opacity-0">
            <em style="color: var(--deep-brown); font-style: italic;">offenen Ohr</em>
          </span>
        </h1>

        <!-- Subline -->
        <p
          id="hero-subline"
          class="font-sans text-lg leading-relaxed mb-10 max-w-xl opacity-0"
          style="color: var(--text-secondary); font-size: clamp(1rem, 2vw, 1.15rem);"
        >
          Ein warmer Ort in Bamberg, an dem Sorgen genauso willkommen sind wie gute Laune.
          Für Menschen aller Schichten – auf Augenhöhe.
        </p>

        <!-- Buttons -->
        <div id="hero-buttons" class="flex flex-wrap gap-4 mb-14 opacity-0">
          <a href="#angebote" class="btn-primary">
            Unsere Angebote
          </a>
          <a href="#vision" class="btn-secondary">
            Mehr erfahren
          </a>
        </div>

        <!-- Scroll cue -->
        <div
          id="hero-scroll-cue"
          class="flex flex-col items-start gap-2 opacity-0"
        >
          <span
            class="font-sans text-sm"
            style="color: var(--text-muted); letter-spacing: 0.06em;"
          >
            Entdecken
          </span>
          <div id="scroll-arrow" class="flex flex-col gap-1">
            <svg
              width="20"
              height="28"
              viewBox="0 0 20 28"
              fill="none"
              aria-hidden="true"
              style="color: var(--terracotta);"
            >
              <path
                d="M10 2 L10 22 M4 16 L10 22 L16 16"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>
        </div>
      </div>

      <!-- Right: Coffee Cup SVG -->
      <div class="hidden lg:flex justify-center items-center relative">
        <div id="coffee-cup-wrapper" class="relative opacity-0">
          <svg
            id="coffee-cup-svg"
            viewBox="0 0 300 380"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full max-w-xs"
            aria-hidden="true"
            role="img"
          >
            <!-- Cup body -->
            <path
              d="M 80,180 Q 75,240 85,280 Q 120,315 150,315 Q 180,315 215,280 Q 225,240 220,180 Z"
              stroke="var(--terracotta)"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="var(--cream)"
              fill-opacity="0.5"
            />
            <!-- Cup rim -->
            <path
              d="M 72,180 Q 150,165 228,180"
              stroke="var(--terracotta)"
              stroke-width="3"
              stroke-linecap="round"
              fill="none"
            />
            <!-- Handle -->
            <path
              d="M 220,210 Q 262,202 260,242 Q 258,278 216,268"
              stroke="var(--terracotta)"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
            <!-- Saucer -->
            <path
              d="M 50,328 Q 90,345 150,348 Q 210,345 250,328"
              stroke="var(--soft-brown)"
              stroke-width="2.5"
              stroke-linecap="round"
              fill="none"
              opacity="0.6"
            />
            <path
              d="M 58,322 Q 150,340 242,322"
              stroke="var(--soft-brown)"
              stroke-width="1.5"
              stroke-linecap="round"
              fill="none"
              opacity="0.4"
            />

            <!-- Cup inner detail -->
            <ellipse
              cx="150"
              cy="185"
              rx="68"
              ry="8"
              stroke="var(--terracotta-light)"
              stroke-width="1.5"
              fill="var(--cream-dark)"
              fill-opacity="0.4"
              opacity="0.6"
            />

            <!-- Steam wisps -->
            <path
              class="steam-waft steam-1"
              d="M 115,170 Q 108,148 118,130 Q 130,112 120,90"
              stroke="var(--terracotta-light)"
              stroke-width="2.5"
              stroke-linecap="round"
              fill="none"
              opacity="0.7"
            />
            <path
              class="steam-waft steam-2"
              d="M 150,164 Q 143,138 153,118 Q 165,96 155,72"
              stroke="var(--warm-gold)"
              stroke-width="2.5"
              stroke-linecap="round"
              fill="none"
              opacity="0.8"
            />
            <path
              class="steam-waft steam-3"
              d="M 185,170 Q 178,148 188,130 Q 200,112 190,90"
              stroke="var(--terracotta-light)"
              stroke-width="2.5"
              stroke-linecap="round"
              fill="none"
              opacity="0.7"
            />

            <!-- Heart on cup -->
            <path
              d="M 140,240 C 140,232 128,228 128,238 C 128,244 140,254 140,254 C 140,254 152,244 152,238 C 152,228 140,232 140,240 Z"
              stroke="var(--warm-gold)"
              stroke-width="1.5"
              fill="var(--warm-gold)"
              fill-opacity="0.25"
              opacity="0.8"
            />
          </svg>
        </div>

        <!-- Floating dot accents around the cup -->
        <div
          class="absolute top-6 right-6 w-3 h-3 rounded-full opacity-30"
          style="background: var(--warm-gold);"
          aria-hidden="true"
        ></div>
        <div
          class="absolute bottom-12 left-4 w-2 h-2 rounded-full opacity-20"
          style="background: var(--sage);"
          aria-hidden="true"
        ></div>
        <div
          class="absolute top-1/3 left-0 w-4 h-4 rounded-full opacity-15"
          style="background: var(--terracotta-light);"
          aria-hidden="true"
        ></div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const tl = gsap.timeline({ delay: 0.2 });

    // Blobs
    tl.to('#hero-blob-1', { opacity: 1, duration: 1.2, ease: 'power2.out' }, 0)
      .to('#hero-blob-2', { opacity: 1, duration: 1.2, ease: 'power2.out' }, 0.2)

      // Badge
      .fromTo(
        '#hero-badge',
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' },
        0.3
      )

      // Headline words
      .fromTo(
        '#hero-word-1',
        { y: 30, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' },
        0.55
      )
      .fromTo(
        '#hero-word-2',
        { y: 30, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out' },
        0.75
      )

      // Subline
      .fromTo(
        '#hero-subline',
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.6, ease: 'power2.out' },
        0.95
      )

      // Buttons
      .fromTo(
        '#hero-buttons',
        { y: 15, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.5, ease: 'power2.out' },
        1.15
      )

      // Scroll cue
      .fromTo(
        '#hero-scroll-cue',
        { opacity: 0 },
        { opacity: 1, duration: 0.5 },
        1.4
      )

      // Coffee cup
      .fromTo(
        '#coffee-cup-wrapper',
        { scale: 0.88, opacity: 0, y: 20 },
        { scale: 1, opacity: 1, y: 0, duration: 1, ease: 'power3.out' },
        0.5
      );

    // Scroll arrow bounce
    gsap.to('#scroll-arrow', {
      y: 6,
      duration: 0.9,
      yoyo: true,
      repeat: -1,
      ease: 'sine.inOut',
    });

    // Steam animations
    const steamPaths = document.querySelectorAll('.steam-waft');
    steamPaths.forEach((steam, i) => {
      gsap.to(steam, {
        y: -10,
        opacity: 0.2,
        duration: 2.2 + i * 0.4,
        yoyo: true,
        repeat: -1,
        ease: 'sine.inOut',
        delay: i * 0.5,
      });
    });
  } else {
    // Show everything without animation
    ['#hero-blob-1', '#hero-blob-2', '#hero-badge', '#hero-word-1', '#hero-word-2',
     '#hero-subline', '#hero-buttons', '#hero-scroll-cue', '#coffee-cup-wrapper'].forEach((id) => {
      const el = document.querySelector(id) as HTMLElement | null;
      if (el) el.style.opacity = '1';
    });
  }
</script>
