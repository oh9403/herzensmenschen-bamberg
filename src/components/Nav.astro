---
---

<nav
  id="main-nav"
  aria-label="Hauptnavigation"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a
        href="/"
        class="font-serif text-xl text-[var(--text-primary)] hover:opacity-80 transition-opacity"
        aria-label="Herzensmenschen Bamberg – Startseite"
      >
        Herzensmenschen <span style="color: var(--warm-gold);">♡</span>
      </a>

      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-8" role="list">
        <li>
          <a
            href="#vision"
            class="nav-link font-sans font-medium text-[0.95rem] text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
          >
            Unsere Vision
          </a>
        </li>
        <li>
          <a
            href="#values"
            class="nav-link font-sans font-medium text-[0.95rem] text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
          >
            Was uns ausmacht
          </a>
        </li>
        <li>
          <a
            href="#angebote"
            class="nav-link font-sans font-medium text-[0.95rem] text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
          >
            Angebote
          </a>
        </li>
        <li>
          <a
            href="#gruenderin"
            class="nav-link font-sans font-medium text-[0.95rem] text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
          >
            Über uns
          </a>
        </li>
        <li>
          <a
            href="#mitmachen"
            class="btn-primary text-sm py-2.5 px-5"
          >
            Mitmachen
          </a>
        </li>
      </ul>

      <!-- Hamburger Button -->
      <button
        id="hamburger"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-[var(--cream-dark)] transition-colors"
      >
        <span class="hamburger-line block w-6 h-0.5 bg-[var(--text-primary)] transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-[var(--text-primary)] transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-[var(--text-primary)] transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
    aria-hidden="true"
  >
    <ul
      class="flex flex-col gap-1 px-6 pb-6 pt-2 bg-[var(--cream)] border-t border-[var(--cream-dark)]"
      role="list"
    >
      <li>
        <a
          href="#vision"
          class="mobile-nav-link block py-3 font-sans font-medium text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
        >
          Unsere Vision
        </a>
      </li>
      <li>
        <a
          href="#values"
          class="mobile-nav-link block py-3 font-sans font-medium text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
        >
          Was uns ausmacht
        </a>
      </li>
      <li>
        <a
          href="#angebote"
          class="mobile-nav-link block py-3 font-sans font-medium text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
        >
          Angebote
        </a>
      </li>
      <li>
        <a
          href="#gruenderin"
          class="mobile-nav-link block py-3 font-sans font-medium text-[var(--text-secondary)] hover:text-[var(--terracotta)] transition-colors"
        >
          Über uns
        </a>
      </li>
      <li class="pt-2">
        <a
          href="#mitmachen"
          class="mobile-nav-link btn-primary block text-center"
        >
          Mitmachen
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const nav = document.getElementById('main-nav');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerLines = document.querySelectorAll('.hamburger-line');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  // Scroll effect
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion && nav) {
    ScrollTrigger.create({
      start: 'top-=60',
      onEnter: () => {
        gsap.to(nav, {
          backgroundColor: 'rgba(250, 246, 241, 0.95)',
          backdropFilter: 'blur(12px)',
          boxShadow: '0 2px 12px rgba(62,39,35,0.06)',
          duration: 0.5,
          ease: 'power2.out',
        });
      },
      onLeaveBack: () => {
        gsap.to(nav, {
          backgroundColor: 'rgba(250, 246, 241, 0)',
          backdropFilter: 'blur(0px)',
          boxShadow: 'none',
          duration: 0.5,
          ease: 'power2.out',
        });
      },
    });
  }

  // Hamburger toggle
  let menuOpen = false;

  function toggleMenu() {
    menuOpen = !menuOpen;

    if (hamburger) {
      hamburger.setAttribute('aria-label', menuOpen ? 'Menü schließen' : 'Menü öffnen');
      hamburger.setAttribute('aria-expanded', String(menuOpen));
    }

    if (mobileMenu) {
      mobileMenu.setAttribute('aria-hidden', String(!menuOpen));
      if (menuOpen) {
        mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
      } else {
        mobileMenu.style.maxHeight = '0';
      }
    }

    // Animate hamburger lines
    if (hamburgerLines.length >= 3) {
      if (menuOpen) {
        gsap.to(hamburgerLines[0], { rotation: 45, y: 8, duration: 0.3 });
        gsap.to(hamburgerLines[1], { opacity: 0, duration: 0.2 });
        gsap.to(hamburgerLines[2], { rotation: -45, y: -8, duration: 0.3 });
      } else {
        gsap.to(hamburgerLines[0], { rotation: 0, y: 0, duration: 0.3 });
        gsap.to(hamburgerLines[1], { opacity: 1, duration: 0.2 });
        gsap.to(hamburgerLines[2], { rotation: 0, y: 0, duration: 0.3 });
      }
    }
  }

  hamburger?.addEventListener('click', toggleMenu);

  // Close menu on mobile link click
  mobileNavLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (menuOpen) toggleMenu();
    });
  });
</script>
